<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Maze Run 3D - Royal eSports</title>
  
  <meta name="theme-color" content="#000000">

  <link rel="stylesheet" href="style.css">
  <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
  <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-firestore.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/GLTFLoader.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/loaders/DRACOLoader.js"></script>
  <script src="https://unpkg.com/peerjs@1.4.7/dist/peerjs.min.js"></script>
  <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&family=Poppins:wght@600;800&display=swap" rel="stylesheet">
  
  <style>
    .ui-icon { vertical-align: middle; margin-right: 6px; }
    .ui-icon-right { vertical-align: middle; margin-left: 6px; }
    @keyframes pulseText { 0% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.2); opacity: 0.8; } 100% { transform: scale(1); opacity: 1; } }
    .countdown-anim { animation: pulseText 1s infinite; }
    .hud-box { background: rgba(0,0,0,0.6); padding: 5px 10px; border: 1px solid #00ffff; border-radius: 6px; color: white; font-family: 'Poppins'; font-size: 10px; margin-bottom: 5px; text-shadow: 1px 1px 2px black; display: flex; align-items: center; }
    button { cursor: pointer; touch-action: manipulation; }

    .pro-login-container { display: flex; position: absolute; top:0; left:0; width:100%; height:100%; z-index: 999999; background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('wall.png') center center / cover no-repeat; padding: 40px 80px; box-sizing: border-box; justify-content: space-between; align-items: center; pointer-events: auto !important; }
    .glass-login-panel { background: rgba(20, 25, 30, 0.4); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); border: 1px solid rgba(255, 255, 255, 0.1); padding: 30px; border-radius: 16px; width: 320px; display: flex; flex-direction: column; box-shadow: 0 15px 35px rgba(0,0,0,0.6); pointer-events: auto !important; }
    .cyber-input { background: rgba(0, 0, 0, 0.5); border: 1px solid #00ffff; color: white; padding: 15px; font-size: 13px; margin-bottom: 15px; border-radius: 8px; outline: none; font-family: 'Poppins', sans-serif; transition: 0.3s; box-sizing: border-box; width: 100%; pointer-events: auto !important; }
    .cyber-input:focus { box-shadow: 0 0 15px rgba(0, 255, 255, 0.4); border-color: #00ff88; }
    .cyber-btn { background: linear-gradient(90deg, #00ffff, #00ff88); border: none; color: #000; font-weight: 800; padding: 15px; font-size: 14px; border-radius: 8px; cursor: pointer; font-family: 'Montserrat', sans-serif; transition: 0.3s; margin-top: 10px; pointer-events: auto !important; }
    .cyber-btn:hover { box-shadow: 0 0 20px rgba(0, 255, 136, 0.6); transform: scale(1.02); }
    .agent-box { background: rgba(255, 255, 255, 0.05); border: 1px solid transparent; padding: 10px; border-radius: 12px; cursor: pointer; display: flex; flex-direction: column; align-items: center; width: 75px; transition: 0.3s; pointer-events: auto !important; }
    .agent-box:hover { background: rgba(255,255,255,0.1); }
  </style>
</head>
<body>

  <div id="pro-splash-screen" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #0a0f14; z-index: 2147483647; display: flex; flex-direction: column; justify-content: center; align-items: center; transition: opacity 0.5s ease-out;">
      <img src="icon.png" style="width: 120px; height: 120px; border-radius: 20px; box-shadow: 0 0 30px rgba(0, 255, 136, 0.4); animation: splashPulse 2s infinite; margin-bottom: 20px;">
      <h1 style="color: white; font-family: 'Montserrat', sans-serif; font-size: 28px; margin: 0; letter-spacing: 3px; text-shadow: 2px 2px 10px rgba(0,0,0,0.8);">MAZE RUN 3D</h1>
      <p style="color: #00ff88; font-family: 'Poppins', sans-serif; font-size: 14px; margin-top: 5px; font-weight: bold; letter-spacing: 2px;">BY ROYAL ESPORTS</p>
      <div style="margin-top: 40px; border: 3px solid rgba(255,255,255,0.1); border-top: 3px solid #00ffff; border-radius: 50%; width: 30px; height: 30px; animation: spin 1s linear infinite;"></div>
      <style>
          @keyframes splashPulse { 0% { transform: scale(1); box-shadow: 0 0 20px rgba(0, 255, 136, 0.2); } 50% { transform: scale(1.05); box-shadow: 0 0 40px rgba(0, 255, 136, 0.6); } 100% { transform: scale(1); box-shadow: 0 0 20px rgba(0, 255, 136, 0.2); } }
          @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
      </style>
  </div>
  <script>
      window.addEventListener('load', function() {
          setTimeout(function() {
              let splash = document.getElementById('pro-splash-screen');
              if(splash) {
                  splash.style.opacity = '0';
                  setTimeout(() => { splash.style.display = 'none'; }, 500);
              }
          }, 3000); // 3 Second timer
      });
  </script>

  <div id="offline-screen" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:radial-gradient(circle, #1a1a1a 0%, #000 100%); z-index:9999999; color:white; text-align:center; font-family:'Montserrat', sans-serif; justify-content:center; align-items:center; flex-direction:column;">
      <div class="icon-container" style="margin-bottom: 25px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#e74c3c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="animation: pulse-red 2s infinite;">
              <line x1="1" y1="1" x2="23" y2="23"></line><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"></path><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"></path><path d="M10.71 5.05A16 16 0 0 1 22.58 9"></path><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"></path><path d="M8.53 16.11a6 6 0 0 1 6.95 0"></path><line x1="12" y1="20" x2="12.01" y2="20"></line>
          </svg>
      </div>
      <h2 style="margin:0; letter-spacing: 2px; font-size: 26px; color: #e74c3c;">CONNECTION LOST</h2>
      <p style="color:#aaa; margin: 10px 0 25px 0; font-family: 'Poppins', sans-serif; font-size: 14px;">Please check your internet settings</p>
      <button onclick="location.reload()" style="cursor:pointer; padding:12px 35px; background:transparent; border: 2px solid #2ecc71; color:#2ecc71; border-radius:30px; font-weight:bold; transition: 0.3s; outline:none; font-family:'Montserrat', sans-serif;">RETRY CONNECTION</button>
      <style>@keyframes pulse-red { 0% { transform: scale(1); filter: drop-shadow(0 0 0px rgba(231, 76, 60, 0)); } 50% { transform: scale(1.1); filter: drop-shadow(0 0 15px rgba(231, 76, 60, 0.5)); } 100% { transform: scale(1); filter: drop-shadow(0 0 0px rgba(231, 76, 60, 0)); } }</style>
  </div>

  <h2 id="screen-alert" style="display:none; position:absolute; top:30%; left:50%; transform:translate(-50%, -50%); color:#ff4444; font-family:'Poppins', sans-serif; font-size:24px; text-shadow:2px 2px 0 #000, -2px -2px 0 #000, 2px -2px 0 #000, -2px 2px 0 #000; z-index:90000; pointer-events:none; white-space: nowrap; align-items:center;"></h2>

  <button id="mic-btn" style="display: none; position: absolute; top: 20px; right: 20px; z-index: 99999; background: rgba(255, 0, 0, 0.5); border: 2px solid #ff4444; border-radius: 50%; width: 50px; height: 50px; color: white; flex-direction: column; justify-content: center; align-items: center; font-family: 'Poppins'; font-size: 11px; font-weight: bold; backdrop-filter: blur(4px); box-shadow: 0 0 10px rgba(255,0,0,0.5); pointer-events: auto !important; touch-action: none;">
      <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="1" x2="23" y2="23"></line><path d="M9 9v3a3 3 0 0 0 5.12 2.12M15 9.34V4a3 3 0 0 0-5.94-.6"></path><path d="M17 16.95A7 7 0 0 1 5 12v-2m14 0v2a7 7 0 0 1-.11 1.23"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>
      OFF
  </button>

  <div id="login-screen" class="pro-login-container">
    <div style="display: flex; flex-direction: column; width: 60%; pointer-events: none;">
      <h1 style="font-family: 'Montserrat', sans-serif; font-size: 45px; color: white; margin: 0; letter-spacing: 2px; text-shadow: 3px 3px 5px rgba(0,0,0,0.8);">MAZE RUN 3D</h1>
      <p style="font-family: 'Poppins', sans-serif; color: #ccc; font-size: 14px; margin: 0 0 30px 0; letter-spacing: 1px;">ROYAL ESPORTS LOGIN</p>
      <h3 style="font-family: 'Montserrat', sans-serif; color: white; font-size: 16px; margin-bottom: 15px;">SELECT YOUR AGENT</h3>
      <div style="display: flex; gap: 15px;">
        <div id="btn-m1" class="char-btn agent-box" onclick="window.selectChar('m1')" style="background: rgba(0, 255, 136, 0.3); border: 1px solid #00ff88;">
            <svg viewBox="0 0 24 24" width="40" height="40" stroke="currentColor" stroke-width="1.5" fill="none" style="color:white; margin-bottom:8px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg><span style="color:white; font-family:'Poppins'; font-size:11px;">Male 1</span>
        </div>
        <div id="btn-m2" class="char-btn agent-box" onclick="window.selectChar('m2')">
            <svg viewBox="0 0 24 24" width="40" height="40" stroke="currentColor" stroke-width="1.5" fill="none" style="color:white; margin-bottom:8px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg><span style="color:white; font-family:'Poppins'; font-size:11px;">Male 2</span>
        </div>
        <div id="btn-f1" class="char-btn agent-box" onclick="window.selectChar('f1')">
            <svg viewBox="0 0 24 24" width="40" height="40" stroke="currentColor" stroke-width="1.5" fill="none" style="color:white; margin-bottom:8px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg><span style="color:white; font-family:'Poppins'; font-size:11px;">Female 1</span>
        </div>
        <div id="btn-f2" class="char-btn agent-box" onclick="window.selectChar('f2')">
            <svg viewBox="0 0 24 24" width="40" height="40" stroke="currentColor" stroke-width="1.5" fill="none" style="color:white; margin-bottom:8px;"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg><span style="color:white; font-family:'Poppins'; font-size:11px;">Female 2</span>
        </div>
      </div>
    </div>
    <div class="glass-login-panel">
      <h2 style="color: white; margin-top: 0; margin-bottom: 25px; font-family: 'Montserrat', sans-serif; font-size: 18px; text-align: center;">ACCOUNT LOGIN</h2>
      <input type="text" id="username-input" class="cyber-input" placeholder="Username" maxlength="12">
      <input type="password" id="password-input" class="cyber-input" placeholder="Password" maxlength="16">
      <button id="login-btn" class="cyber-btn" onclick="window.saveProfile()">ENTER GAME HUB</button>
    </div>
  </div>

  <div id="loading-screen" class="menu-background" style="display: none; z-index: 15000; position: absolute; top:0; left:0; width:100%; height:100%; justify-content: center; align-items: center;">
    <div style="text-align: center; width: 70%; max-width: 300px;">
        <h1 class="main-title" id="load-title" style="font-size: 16px; margin-bottom: 15px; letter-spacing: 2px;">LOADING ASSETS...</h1>
        <div style="width: 100%; height: 4px; background: rgba(255,255,255,0.1); border-radius: 10px;"><div id="load-fill" style="width: 0%; height: 100%; background: #00ffff; transition: 0.2s;"></div></div>
    </div>
  </div>

  <div id="main-menu" style="display: none; position: absolute; width:100%; height:100%; z-index: 5000; background: transparent; padding: 20px 40px; box-sizing: border-box; justify-content: space-between; align-items: center; pointer-events: none;">
    <div style="max-width: 260px; display: flex; flex-direction: column; gap: 12px; pointer-events: auto !important;">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px;">
        <div>
          <h1 class="main-title" style="font-size: 22px; text-align: left; margin:0; text-shadow: 2px 2px 4px #000;">MAZE RUN 3D</h1>
          <p class="sub-title" id="welcome-msg" style="color: #00ff88; text-align: left; margin: 2px 0 0 0; font-size: 10px; font-weight: bold;">Welcome!</p>
        </div>
        <button onclick="window.logoutProfile()" class="action-btn" style="background: rgba(255,0,0,0.15); color: #ff4444; border: 1px solid rgba(255,0,0,0.4); padding: 6px 10px; border-radius: 4px; font-family: 'Poppins'; font-size: 9px;">LOGOUT</button>
      </div>

      <div style="display: flex; flex-direction: column; gap: 8px;">
          <button class="action-btn green-glow" onclick="window.startSinglePlayer()" style="font-size: 11px; padding: 10px; border-radius: 6px; display:flex; justify-content:center; align-items:center;">
              <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" class="ui-icon"><rect x="2" y="6" width="20" height="12" rx="2" ry="2"></rect><line x1="6" y1="12" x2="10" y2="12"></line><line x1="8" y1="10" x2="8" y2="14"></line><line x1="15" y1="13" x2="15.01" y2="13"></line><line x1="18" y1="11" x2="18.01" y2="11"></line></svg> SOLO RUN
          </button>
          <button class="action-btn orange-glow" onclick="document.getElementById('manual-mp-overlay').style.display='flex';" style="font-size: 11px; padding: 10px; border-radius: 6px; display:flex; justify-content:center; align-items:center;">
              <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" class="ui-icon"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg> SQUAD HUB
          </button>
          
          <div style="display: flex; gap: 6px;">
            <button class="action-btn" onclick="document.getElementById('change-char-overlay').style.display='flex';" style="flex:1; background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255,255,255,0.3); color: #fff; font-size: 9px; padding: 8px; border-radius: 6px; display:flex; justify-content:center; align-items:center;">
                <svg viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" stroke-width="2" fill="none" class="ui-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg> AGENT
            </button>
            <button class="action-btn" onclick="window.showStats()" style="flex:1; background: rgba(0, 200, 255, 0.2); border: 1px solid rgba(0,255,255,0.4); color: #fff; font-size: 9px; padding: 8px; border-radius: 6px; display:flex; justify-content:center; align-items:center;">
                <svg viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" stroke-width="2" fill="none" class="ui-icon"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg> STATS
            </button>
            <button class="action-btn" id="btn-graphics" onclick="window.toggleGraphics()" style="flex:1; background: rgba(255, 170, 0, 0.2); border: 1px solid rgba(255,170,0,0.4); color: #fff; font-size: 9px; padding: 8px; border-radius: 6px; display:flex; justify-content:center; align-items:center;">
                <svg viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" stroke-width="2" fill="none" class="ui-icon"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg> HIGH
            </button>
          </div>
      </div>
    </div>
    <div style="width: 200px; height: 180px; background: rgba(0,0,0,0.5); border: 1px solid rgba(0,255,255,0.2); border-radius: 12px; padding: 15px; display: flex; flex-direction: column; backdrop-filter: blur(8px); pointer-events: auto !important;">
        <h3 style="color: #00ffff; font-family: 'Poppins'; font-size: 11px; margin-top: 0; margin-bottom: 12px; display:flex; align-items:center; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 8px;">
            <svg viewBox="0 0 24 24" width="12" height="12" fill="#00ff88" class="ui-icon"><circle cx="12" cy="12" r="8"></circle></svg> ONLINE
        </h3>
        <div id="live-friends-list" style="overflow-y: auto; flex: 1; display: flex; flex-direction: column; gap: 8px;"><p style="color:#aaa; font-size: 10px; text-align: center; margin-top: 20px;">Scanning network...</p></div>
    </div>
  </div>

  <div class="overlay" id="change-char-overlay" style="z-index: 6000; display:none; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); position: absolute; top:0; left:0; width:100%; height:100%; justify-content: center; align-items: center; pointer-events: auto !important;">
    <div class="overlay-box" style="border-color: #00ff88; width: 85%; max-width: 300px; padding: 25px; border-radius: 12px; text-align: center;">
      <h2 style="color: #00ff88; font-family: 'Poppins'; font-size: 16px; margin-bottom: 15px;">CHANGE AGENT</h2>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px;">
        <button class="action-btn char-change-btn" onclick="window.updateCharacter('m1')" style="background: rgba(255, 255, 255, 0.1); border: 1px solid transparent; color:white; padding: 10px; font-size: 10px; border-radius: 6px; display:flex; align-items:center; justify-content:center;"><svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" class="ui-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg> MALE 1</button>
        <button class="action-btn char-change-btn" onclick="window.updateCharacter('m2')" style="background: rgba(255, 255, 255, 0.1); border: 1px solid transparent; color:white; padding: 10px; font-size: 10px; border-radius: 6px; display:flex; align-items:center; justify-content:center;"><svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" class="ui-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg> MALE 2</button>
        <button class="action-btn char-change-btn" onclick="window.updateCharacter('f1')" style="background: rgba(255, 255, 255, 0.1); border: 1px solid transparent; color:white; padding: 10px; font-size: 10px; border-radius: 6px; display:flex; align-items:center; justify-content:center;"><svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" class="ui-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg> FEMALE 1</button>
        <button class="action-btn char-change-btn" onclick="window.updateCharacter('f2')" style="background: rgba(255, 255, 255, 0.1); border: 1px solid transparent; color:white; padding: 10px; font-size: 10px; border-radius: 6px; display:flex; align-items:center; justify-content:center;"><svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" class="ui-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg> FEMALE 2</button>
      </div>
      <button class="action-btn" onclick="document.getElementById('change-char-overlay').style.display='none'" style="background: rgba(255,0,0,0.2); border: 1px solid #ff4444; color: white; padding: 8px 20px; font-size: 10px; border-radius: 6px;">CANCEL</button>
    </div>
  </div>

  <div class="overlay" id="manual-mp-overlay" style="z-index: 6000; display:none; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); position: absolute; top:0; left:0; width:100%; height:100%; justify-content: center; align-items: center; pointer-events: auto !important;">
    <div class="overlay-box" style="border-color: #ffaa00; width: 85%; max-width: 280px; padding: 25px; border-radius: 12px;">
      <h2 style="color: #ffaa00; font-family: 'Poppins'; font-size: 16px; margin-bottom: 15px;">MANUAL CONNECTION</h2>
      <button class="action-btn orange-glow" id="btn-create" onclick="window.createRoom()" style="font-size: 11px; padding: 10px; width: 100%; margin-bottom: 10px; border-radius: 6px;">HOST NEW MATCH</button>
      <div id="room-info" style="display: none; background: rgba(0,0,0,0.4); padding: 10px; border-radius: 6px; text-align: center; margin-bottom: 10px;"><p style="color:#aaa; font-size:9px; margin:0;">YOUR ROOM ID</p><h2 id="room-id-display" style="color:#00ffff; margin:5px 0 0 0; letter-spacing: 2px; font-size: 18px;">...</h2></div>
      <div style="display: flex; gap: 8px; margin-bottom: 15px;"><input type="text" id="join-id-input" class="glass-input" placeholder="ENTER ID" style="font-size: 11px; padding: 8px; flex: 1; border-radius: 6px;"><button class="action-btn yellow-glow" id="btn-join" onclick="window.joinRoom()" style="font-size: 11px; padding: 8px; flex: 0.5; border-radius: 6px;">JOIN</button></div>
