      <button class="action-btn" onclick="document.getElementById('manual-mp-overlay').style.display='none'" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.2); color: white; padding: 8px; font-size: 10px; border-radius: 6px;">CLOSE</button>
    </div>
  </div>

  <div class="overlay" id="invite-alert" style="z-index: 7000; display:none; background: rgba(0,0,0,0.7); position: absolute; top:0; left:0; width:100%; height:100%; justify-content: center; align-items: center; pointer-events: auto !important;">
      <div style="background: rgba(15,25,35,0.95); border: 1px solid #00ffff; padding: 20px; border-radius: 12px; text-align: center;"><h3 style="color: white; font-family: 'Poppins'; font-size: 14px;">SQUAD INVITE!</h3><p style="color: #00ff88;"><span id="inviter-name">PLAYER</span> invited you!</p><div style="display: flex; gap: 10px;"><button class="action-btn green-glow" onclick="window.acceptInvite()" style="flex:1;">ACCEPT</button><button class="action-btn" onclick="window.declineInvite()" style="background: rgba(255,0,0,0.2); border: 1px solid #ff4444; color: white; flex:1;">DECLINE</button></div></div>
  </div>
  
  <div class="overlay" id="stats-overlay" style="z-index: 6000; display:none; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); position: absolute; top:0; left:0; width:100%; height:100%; justify-content: center; align-items: center; pointer-events: auto !important;">
      <div class="overlay-box" style="background: rgba(10, 15, 20, 0.95); border: 2px solid #00ffff; width: 90%; max-width: 500px; border-radius: 12px; padding: 0; display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 0 20px rgba(0,255,255,0.2);">
          <div style="background: rgba(0,255,255,0.1); padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(0,255,255,0.3);">
              <h1 style="font-family: 'Poppins'; font-size: 16px; margin: 0; color: #00ffff; letter-spacing: 1px;">PLAYER PROFILE</h1>
              <button class="action-btn" style="background: transparent; color: #ff4444; border: 1px solid #ff4444; width: 28px; height: 28px; border-radius: 5px; display: flex; align-items: center; justify-content: center; padding: 0; cursor: pointer; font-weight: bold;" onclick="document.getElementById('stats-overlay').style.display='none';">X</button>
          </div>
          <div style="padding: 20px; display: flex; flex-direction: row; gap: 20px; flex-wrap: wrap;">
              <div style="flex: 1; min-width: 150px;">
                  <h2 id="stat-name" style="color: white; font-size: 14px; margin-top: 0; margin-bottom: 10px; text-transform: uppercase;">USERNAME</h2>
                  <div style="background: rgba(0,0,0,0.4); padding: 15px; border-radius: 8px; font-family: 'Poppins'; font-size: 12px; display: flex; flex-direction: column; gap: 8px; border: 1px solid rgba(255,255,255,0.05);">
                      <div style="display: flex; justify-content: space-between;"><span style="color: #ffd700;">Coins:</span> <span id="stat-coins" style="color:white; font-weight:bold;">0</span></div>
                      <div style="display: flex; justify-content: space-between;"><span style="color: #00ff88;">Wins:</span> <span id="stat-wins" style="color:white; font-weight:bold;">0</span></div>
                      <div style="display: flex; justify-content: space-between;"><span style="color: #ff4444;">Losses:</span> <span id="stat-losses" style="color:white; font-weight:bold;">0</span></div>
                      <div style="display: flex; justify-content: space-between; margin-top: 5px; padding-top: 5px; border-top: 1px solid rgba(255,255,255,0.1);"><span style="color: #aaa;">Played:</span> <span id="stat-matches" style="color:white; font-weight:bold;">0</span></div>
                  </div>
              </div>
              <div style="flex: 1.5; min-width: 200px; display: flex; flex-direction: column;">
                  <h3 style="color: #00ffff; font-size: 12px; margin-top: 0; margin-bottom: 10px; font-family: 'Poppins';">RECENT MATCHES</h3>
                  <div id="match-history-list" style="background: rgba(0,0,0,0.4); padding: 10px; border-radius: 8px; flex: 1; min-height: 120px; max-height: 150px; overflow-y: auto; font-family: monospace; font-size: 11px; border: 1px solid rgba(255,255,255,0.05);"></div>
              </div>
          </div>
      </div>
  </div>
  
  <div id="lobby-screen" style="display: none; position: absolute; top:0; left:0; width:100%; height:100%; z-index: 4000; flex-direction: column; justify-content: space-between; pointer-events: none;">
      <div style="padding: 20px; pointer-events: auto !important;"><div style="background: rgba(0,0,0,0.5); display: inline-block; padding: 6px 16px; border-radius: 20px;"><p style="margin:0; color:#fff; font-size: 9px;">SQUAD ROOM</p><h3 id="lobby-room-id" style="margin:0; color:#00ffff; font-size: 13px;">----</h3></div></div>
      <div style="padding: 20px; display: flex; flex-direction: column; align-items: flex-end; pointer-events: auto !important;"><div style="display: flex; gap: 10px;"><button class="action-btn" onclick="window.exitToMainMenu()" style="background: rgba(0,0,0,0.6); border: 1px solid rgba(255,0,0,0.4); color: #ff4444; padding: 10px; font-size: 11px;">EXIT</button><button id="btn-ready" class="action-btn yellow-glow" onclick="window.toggleReady()" style="display:none; padding: 10px; font-size: 12px;">READY</button><button id="btn-start-match" class="action-btn" onclick="window.startMultiplayerMatch()" style="display:none; background: rgba(0,0,0,0.6); color: #aaa; padding: 10px; font-size: 12px;" disabled>WAITING SQUAD...</button></div></div>
  </div>
  
  <div id="lobby-names-hud" style="display: none; position: absolute; top:0; left:0; width:100%; height:100%; z-index: 3000; pointer-events: none;"><div style="position: absolute; bottom: 20%; left: 35%; text-align: center; transform: translateX(-50%);"><p id="lobby-p1-name" style="color: #fff; margin: 0; font-size: 14px;">YOU</p><div id="lobby-p1-status" style="width: 10px; height: 10px; background: #00ffff; border-radius: 50%; margin: 4px auto;"></div></div><div style="position: absolute; bottom: 20%; right: 35%; text-align: center; transform: translateX(50%);"><p id="lobby-p2-name" style="color: #fff; margin: 0; font-size: 14px;">WAITING...</p><div id="lobby-p2-status" style="width: 10px; height: 10px; background: #ff4444; border-radius: 50%; margin: 4px auto;"></div></div></div>

  <div id="countdown-overlay" style="display:none; position:absolute; top:0; left:0; width:100%; height:100%; z-index:8000; justify-content:center; align-items:center; background: rgba(0,0,0,0.6);"><h1 id="countdown-text" class="countdown-anim" style="font-size: 120px; color: #00ff88;">5</h1></div>

  <div id="game-ui" style="display: none;">
    <div id="vignette"></div>
    
    <button id="spectate-btn" onclick="window.toggleSpectate(event)" class="action-btn" style="display:none; touch-action: manipulation; position: absolute; top: 15px; left: 50%; transform: translateX(-50%); width: auto; z-index: 9999; background: rgba(0, 200, 255, 0.3); border: 1px solid #00ffff; color: white; padding: 8px 20px; font-size: 11px; border-radius: 20px; pointer-events: auto !important;">WATCH OPPONENT</button>
    
    <button id="drop-med-btn" onclick="window.dropMedkit()" style="display:none; position: absolute; bottom: 100px; right: 20px; z-index: 9999; background: rgba(0, 255, 136, 0.5); border: 2px solid #00ff88; border-radius: 50%; width: 50px; height: 50px; color: white; flex-direction: column; justify-content: center; align-items: center; font-family: 'Poppins'; font-size: 9px; font-weight: bold; pointer-events: auto !important; box-shadow: 0 0 10px rgba(0,255,136,0.5);">
        DROP<svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" style="margin-top:2px;"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path><line x1="12" y1="11" x2="12" y2="17"></line><line x1="9" y1="14" x2="15" y2="14"></line></svg>
    </button>

    <div id="topLeftHUD" style="position: absolute; top: 10px; left: 10px; z-index: 5000;">
        <div class="hud-box" id="player-role">PLAYER 1</div>
        <div class="hud-box timer-box" id="timer" style="color: #ffaa00; font-weight: bold;">TIME: 05:00</div>
        <div class="hud-box" id="level-display" style="background: rgba(0,255,136,0.2); border-color: #00ff88; color: #00ff88; font-weight: bold; margin-top: 5px;">LEVEL 1</div>
        <div id="health-container" style="position: relative; width: 100%; height: 16px; background: rgba(0,0,0,0.6); border: 1px solid #ff4444; border-radius: 6px; margin-top: 5px; overflow: hidden;">
            <div id="health-fill" style="width: 100%; height: 100%; background: #ff4444; box-shadow: 0 0 10px #ff0000; transition: width 0.2s, background 0.3s;"></div>
            <div id="health-text" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; text-align: center; color: white; font-size: 11px; font-weight: bold; line-height: 16px; text-shadow: 1px 1px 2px black;">100%</div>
        </div>
        <div class="hud-box" id="teammate-health-box" style="display:none; background: rgba(0,0,0,0.8); border-color: #ffaa00; color: #ffaa00; font-weight: bold; margin-top: 5px;">MATE: 100% <svg viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" stroke-width="2" fill="#ff4444" class="ui-icon-right"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg></div>
        <div class="hud-box coin-box" id="coin-counter" style="margin-top: 5px;">COINS: 0</div>
    </div>
    <div id="minimapContainer"><canvas id="minimap" width="130" height="130"></canvas></div>
    <div id="joystick-wrapper"><div id="joystick-base"><div id="joystick-stick"></div></div></div>
    <audio id="remote-audio" autoplay playsinline></audio>
  </div>

  <div class="overlay" id="exit-confirm-overlay" style="z-index: 9000; display:none; position: absolute; top:0; left:0; width:100%; height:100%; justify-content: center; align-items: center; pointer-events: auto !important;"><div class="overlay-box" style="border-color: #ffaa00; max-width: 280px; padding: 25px; border-radius: 12px;"><h1 style="color: #ffaa00;">LEAVE MATCH?</h1><div style="display: flex; gap: 10px;"><button class="action-btn green-glow" onclick="window.resumeGame()" style="width: 50%;">RESUME</button><button class="action-btn" onclick="window.exitToMainMenu()" style="background:rgba(255,0,0,0.15); border:1px solid rgba(255,0,0,0.5); color:white; width: 50%;">EXIT</button></div></div></div>
  
  <div class="overlay" id="endScreen" style="display:none; position: absolute; top:0; left:0; width:100%; height:100%; z-index:9500; justify-content: center; align-items: center; pointer-events: auto !important;"><div class="overlay-box" id="end-box" style="border-radius: 12px; display:flex; flex-direction:column; align-items:center; text-align:center;"><h1 id="end-title" style="display:flex; align-items:center; justify-content:center;">RESULT</h1><p id="end-desc">Stats</p><div id="end-solo-btns" style="display:none; width:100%;"><button class="action-btn" style="background: #fff; color: #000; width:100%;" onclick="window.exitToMainMenu()">MAIN MENU</button></div><div id="end-mp-btns" style="display:none; flex-direction: column; gap: 10px; width:100%;"><button class="action-btn green-glow" onclick="window.triggerReturnToLobby()">RETURN LOBBY</button><button class="action-btn" style="background: rgba(255,0,0,0.15); color: #fff;" onclick="window.exitToMainMenu()">LEAVE SQUAD</button></div></div></div>

  <script src="game.js"></script>
  <script src="multiplayer.js"></script>

  <script>
    document.addEventListener('click', function() {
        if (typeof audioContext !== 'undefined' && audioContext.state === 'suspended') {
            audioContext.resume().then(() => console.log("🔊 Audio System Unlocked!"));
        }
    }, { once: true });

    window.addEventListener('online', function() { document.getElementById('offline-screen').style.display = 'none'; });
    window.addEventListener('offline', function() { document.getElementById('offline-screen').style.display = 'flex'; });
    if (!navigator.onLine) { document.getElementById('offline-screen').style.display = 'flex'; }
  </script>

  <script>
    window.forceLandscapeLock = async () => { try { let elem = document.documentElement; if (!document.fullscreenElement) { if (elem.requestFullscreen) await elem.requestFullscreen(); else if (elem.webkitRequestFullscreen) await elem.webkitRequestFullscreen(); } if(screen.orientation && screen.orientation.lock) await screen.orientation.lock('landscape'); } catch (err) {} };
    window.resumeGame = function() { document.getElementById('exit-confirm-overlay').style.display = 'none'; window.forceLandscapeLock(); };
    document.addEventListener('fullscreenchange', () => { if (!document.fullscreenElement && document.getElementById('game-ui').style.display === 'block') { document.getElementById('exit-confirm-overlay').style.display = 'flex'; } });
    history.pushState({ inGame: true }, '', window.location.href);
    window.addEventListener('popstate', function(event) { if (document.getElementById('game-ui').style.display === 'block') { history.pushState({ inGame: true }, '', window.location.href); document.getElementById('exit-confirm-overlay').style.display = 'flex'; } });
  </script>
